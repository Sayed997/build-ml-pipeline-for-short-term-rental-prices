name: basic_cleaning
conda_env: conda.yml

entry_points:
  main:
    parameters:

      input_artifact:
        description: Name of the input raw dataset artifact to download from W&B
        type: string

      output_artifact:
        description: Name of the cleaned dataset artifact to upload to W&B
        type: string

      output_type:
        description: Artifact type for the cleaned dataset (e.g. 'clean_sample')
        type: string

      output_description:
        description: A brief description of the output artifact (cleaned dataset)
        type: string

      min_price:
        description: Minimum allowed price; rows with price below this will be dropped
        type: float

      max_price:
        description: Maximum allowed price; rows with price below this will be dropped
        type: float


    command: >-
        python run.py  --input_artifact {input_artifact}  --output_artifact {output_artifact}  --output_type {output_type}  --output_description {output_description}  --min_price {min_price}  --max_price {max_price} 
